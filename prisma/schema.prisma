generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String       @id @default(cuid())
  name           String
  email          String       @unique
  hashedPassword String
  emailVerified  Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  ownedLists     List[]       @relation("OwnedLists")
  memberLists    ListMember[]
  sentInvites    ListInvite[]
}

model List {
  id        String       @id @default(cuid())
  name      String
  ownerId   String
  owner     User         @relation("OwnedLists", fields: [ownerId], references: [id], onDelete: Cascade)
  members   ListMember[]
  items     Item[]
  invites   ListInvite[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model ListMember {
  listId   String
  userId   String
  list     List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@id([listId, userId])
}

model ListInvite {
  id          String   @id @default(cuid())
  listId      String
  list        List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  email       String
  invitedById String
  inviter     User     @relation(fields: [invitedById], references: [id], onDelete: Cascade)
  token       String   @unique
  accepted    Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model Item {
  id        String   @id @default(cuid())
  name      String
  quantity  String?
  category  String?
  addedBy   String
  month     Int
  year      Int
  checked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  listId    String
  list      List     @relation(fields: [listId], references: [id], onDelete: Cascade)
}
