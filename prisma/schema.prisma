generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Item {
  id        String   @id @default(cuid())
  name      String
  quantity  String?
  category  String?
  addedBy   String
  month     Int
  year      Int
  checked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
